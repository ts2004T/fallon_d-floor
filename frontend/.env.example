# Base URL of the FastAPI backend.
#
# Used for both server-side rendering (Next.js server -> API) and
# client-side requests (browser -> API, e.g. the Analytics Player Drilldown).
#
# In production this MUST be a publicly reachable URL, and the API's
# ALLOWED_ORIGINS must include this site's deployed origin.
NEXT_PUBLIC_API_URL=http://localhost:8000
